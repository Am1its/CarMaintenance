generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Dashboard {
  id         String   @id @default(uuid())
  token      String   @unique
  ownerEmail String?
  createdAt  DateTime @default(now())
  cars       Car[]
}

model Car {
  id                    String            @id @default(uuid())
  dashboardId           String
  dashboard             Dashboard         @relation(fields: [dashboardId], references: [id])
  label                 String
  licensePlate          String?
  lastServiceDate       DateTime?
  lastServiceKm         Int?
  currentKm             Int?
  serviceIntervalMonths Int               @default(6)
  serviceIntervalKm     Int               @default(10000)
  nextTestDate          DateTime?
  trackBattery          Boolean           @default(false)
  lastBatteryDate       DateTime?
  lastBatteryKm         Int?
  notes                 String?
  photoUrl              String?
  updatedAt             DateTime          @updatedAt
  notificationLogs      NotificationLog[]
  serviceLogs           ServiceLog[]
  carTasks              CarTask[]
}

enum AlertType {
  TEST_30D
  TEST_14D
  TEST_OVERDUE
  SERVICE_DATE_30D
  SERVICE_DATE_14D
  SERVICE_DATE_OVERDUE
  SERVICE_KM_1000
  SERVICE_KM_300
}

enum LogType {
  SERVICE_DONE
  TEST_DONE
  BATTERY_DONE
}

model ServiceLog {
  id        String   @id @default(uuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  type      LogType
  km        Int?
  createdAt DateTime @default(now())
}

model CarTask {
  id        String   @id @default(uuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  text      String
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NotificationLog {
  id        String    @id @default(uuid())
  carId     String
  car       Car       @relation(fields: [carId], references: [id], onDelete: Cascade)
  alertType AlertType
  sentAt    DateTime  @default(now())
}
